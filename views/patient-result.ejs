<!DOCTYPE html>
<html>
<head>
  <title>Queue Status</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet">
</head>
<body class="bg-light">

<%- include('partials/navbar') %>


   <div class="bg-success text-white py-5">
    <div class="container text-center">
      <h1 class="fw-bold mb-2">
        🏥 Clinic Queue Management System
      </h1>
      <p class="fs-5 opacity-75">
        Reduce waiting confusion · Track queue status · Improve patient experience
      </p>
    </div>
  </div>

<!-- STATUS DISPLAY -->
  <% if (typeof nowServing !== "undefined") { %>

  <div class="row g-4 text-center">

    <!-- NOW SERVING -->
    <div class="col-md-4">
      <div class="card shadow border-0 h-100">
        <div class="card-body">
          <div class="fs-1">🩺</div>
          <p class="text-muted mb-1">Now Serving</p>
          <h1 class="fw-bold text-success">
            Token <%= nowServing %>
          </h1>
        </div>
      </div>
    </div>

    <!-- PATIENTS AHEAD -->
    <div class="col-md-4">
      <div class="card shadow border-0 h-100">
        <div class="card-body">
          <div class="fs-1">👥</div>
          <p class="text-muted mb-1">Patients Ahead</p>
          <h1 class="fw-bold text-primary">
            <%= patientsAhead %>
          </h1>
          <p class="text-muted mb-0">
            Please stay alert for your turn
          </p>
        </div>
      </div>
    </div>

    <!-- ESTIMATED TIME -->
    <div class="col-md-4">
      <div class="card shadow border-0 h-100">
        <div class="card-body">
          <div class="fs-1">⏱️</div>
          <p class="text-muted mb-1">Estimated Waiting Time</p>
          <h1 class="fw-bold text-secondary">
            <%= estimatedTime %> (<%= t%> min)
          </h1>
          <p class="text-muted mb-0">
            Based on average consultation time
          </p>
        </div>
      </div>
    </div>

  </div>

  <!-- REASSURANCE MESSAGE -->
  <div class="text-center mt-4">
    <p class="text-muted fst-italic">
      Thank you for your patience. Please be available when your token is called.
    </p>
  </div>

  <% } %>
<!--reload-->
</div>
  <script src="/socket.io/socket.io.js"></script>

<script>
  const socket = io();

  socket.on("queueUpdated", () => {
    location.reload();
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
