<!DOCTYPE html>
<html>
<head>
  <title>FAQ | Patient Queue System</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet">
</head>

<body class="bg-light">

<%- include('partials/navbar') %>

<!-- HEADER -->
<div class="bg-warning text-dark py-5">
  <div class="container text-center">
    <h2 class="fw-bold mb-2">Frequently Asked Questions</h2>
    <p class="mb-0">
      Common questions from patients
    </p>
  </div>
</div>

<div class="container my-5">

  <div class="accordion" id="faqAccordion">

    <!-- Q1 -->
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#q1">
          What is a token number?
        </button>
      </h2>
      <div id="q1" class="accordion-collapse collapse show">
        <div class="accordion-body">
          A token number represents your position in the queue and is provided
          at the reception desk.
        </div>
      </div>
    </div>

    <!-- Q2 -->
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#q2">
          How is waiting time calculated?
        </button>
      </h2>
      <div id="q2" class="accordion-collapse collapse">
        <div class="accordion-body">
          Waiting time is estimated based on the number of patients ahead of you
          and the average consultation time.
        </div>
      </div>
    </div>

    <!-- Q3 -->
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#q3">
          What if I lose my token number?
        </button>
      </h2>
      <div id="q3" class="accordion-collapse collapse">
        <div class="accordion-body">
          Please contact the reception desk to retrieve your token information.
        </div>
      </div>
    </div>

    <!-- Q4 -->
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#q4">
          Do I need to refresh the page?
        </button>
      </h2>
      <div id="q4" class="accordion-collapse collapse">
        <div class="accordion-body">
          You can refresh manually to see updated queue status.
          Real-time updates may be added in future versions.
        </div>
      </div>
    </div>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
