<!DOCTYPE html>
<html>
<head>
  <title>Patient Queue Status</title>

  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet">
</head>

<body class="bg-light">

<%- include('partials/navbar') %>





<!-- HEADER -->
<div class="bg-success text-white py-5">
  <div class="container text-center">
    <h2 class="fw-bold mb-2">🧍 Patient Queue Status</h2>
    <p class="mb-0 opacity-75 fs-6">
      Enter your token number to see your current position in the queue
    </p>
  </div>
</div>

<div class="container my-5">

  <div class="row justify-content-center">
    <div class="col-md-6">

      <!-- CARD -->
      <div class="card shadow border-0">
        <div class="card-body p-4">

          <h5 class="fw-semibold mb-3 text-center">
            Check Your Queue Status
          </h5>

          <form action="/patient-status" method="POST">
            <label class="form-label fw-semibold">
              Token Number
            </label>

            <input
              type="number"
              name="token"
              class="form-control form-control-lg mb-2"
              placeholder="e.g. 12"
              required 
              min=<%=min%>
              max=<%= max %>
            >

            <div class="form-text mb-3">
              Your token number was provided at the reception desk.
            </div>

            <div class="d-grid">
              <button class="btn btn-success btn-lg">
                Check Status
              </button>
            </div>
          </form>

          <!-- ERROR MESSAGE (if any) -->
          <% if (typeof error !== "undefined") { %>
            <div class="alert alert-danger mt-4 text-center">
              <%= error %>
            </div>
          <% } %>

        </div>
      </div>

      <!-- HELPER NOTE -->
      <div class="text-center mt-4">
        <p class="text-muted fst-italic mb-0">
          Please keep your token handy and be available when your number is called.
        </p>
      </div>

    </div>
  </div>

</div>

<script
  src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js">
</script>

</body>
</html>
