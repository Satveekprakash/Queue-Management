<!DOCTYPE html>
<html>
<head>
  <title>Queue Alerts</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet">
</head>

<body class="bg-light">

  <!-- NAVBAR -->
  <%- include('partials/navbar') %>

  <!-- HEADER -->
  <div class="bg-success text-white py-4">
    <div class="container text-center">
      <h2 class="fw-bold">🔔 Queue Alerts</h2>
      <p class="mb-0 opacity-75">
        Get notified when your turn is near
      </p>
    </div>
  </div>

  <!-- ALERT FORM -->
  <div class="container my-5">
    <div class="row justify-content-center">
      <div class="col-md-7">

        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-body p-4">

            <h4 class="fw-semibold mb-3 text-center">Enable Alerts</h4>

            <p class="text-muted text-center mb-4">
              Enter your token number and mobile number to receive queue updates.
            </p>

            <form action="/alerts" method="POST">
              <div class="row g-3 align-items-end">

                <!-- Token Number -->
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Token Number</label>
                  <input
                    type="number"
                    name="tokenNumber"
                    class="form-control"
                    placeholder="Example: 23"
                    min="1"
                    required
                  />
                </div>

                <!-- Mobile Number -->
                <div class="col-md-5">
                  <label class="form-label fw-semibold">Mobile Number</label>
                  <input
                    type="text"
                    name="mobileNumber"
                    class="form-control"
                    placeholder="Example: 9876543210"
                    required
                  />
                </div>

                <!-- Button -->
                <div class="col-md-3 d-grid">
                  <button type="submit" class="btn btn-success">
                    Enable Alerts
                  </button>
                </div>

              </div>
            </form>

            <!-- Info -->
            <div class="alert alert-light border mt-4 small">
              You will receive updates when:
              <ul class="mb-0 mt-2">
                <li>7 patients are ahead</li>
                <li>2 patients are ahead</li>
                <li>It is your turn</li>
              </ul>
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>

  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js">
  </script>

</body>
</html>